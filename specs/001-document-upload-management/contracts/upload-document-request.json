{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upload Document Request",
  "description": "Request payload for uploading a document",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Document title"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional document description"
    },
    "category": {
      "type": "string",
      "enum": ["Project Documents", "Team Resources", "Personal Files", "Reports", "Presentations", "Other"],
      "description": "Document category"
    },
    "projectId": {
      "type": "integer",
      "description": "Optional associated project ID"
    },
    "tags": {
      "type": "string",
      "maxLength": 500,
      "description": "Comma-separated tags"
    },
    "file": {
      "type": "string",
      "description": "Base64 encoded file content (for API contract definition)",
      "contentEncoding": "base64"
    },
    "fileName": {
      "type": "string",
      "description": "Original file name"
    },
    "mimeType": {
      "type": "string",
      "description": "MIME type of the file"
    }
  },
  "required": ["title", "category", "file", "fileName", "mimeType"]
}